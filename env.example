# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=solicitud_credito
DB_USER=root
DB_PASS=

# Configuración SendGrid para envío de correos
# IMPORTANTE: Reemplaza TU_API_KEY_AQUI con tu API key real de SendGrid
SENDGRID_API_KEY=TU_API_KEY_AQUI
SENDGRID_FROM_EMAIL=noreply@automarketrentacar.com
SENDGRID_FROM_NAME=AutoMarket Seminuevos
SENDGRID_REPLY_TO=noreply@automarketrentacar.com
SENDGRID_REPLY_TO_NAME=AutoMarket Seminuevos - Soporte
SENDGRID_DEBUG=false

# URL de la aplicación
APP_URL=http://localhost:8086

# Chatbot (OpenAI). Crear clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional: modelo (por defecto gpt-4o-mini)
# CHATBOT_MODEL=gpt-4o-mini

# Configuración MySQL para Docker
MYSQL_ROOT_PASSWORD=motus_root_2024
MYSQL_DATABASE=motus_baes
MYSQL_USER=motus_user
MYSQL_PASSWORD=motus_pass_2024
