# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=solicitud_credito
DB_USER=root
DB_PASS=

# Correo: solo Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Hostname sin https (el SDK de Resend lo usa así)
RESEND_BASE_URL=api.resend.com
# Producción: correo del dominio verificado en Resend. Pruebas: onboarding@resend.dev
# En Docker: define MAIL_* aquí; docker-compose ya no fuerza onboarding@resend.dev por defecto
MAIL_FROM_EMAIL=notificaciones@tudominio.com
MAIL_FROM_NAME=AutoMarket Seminuevos
MAIL_REPLY_TO=
MAIL_REPLY_TO_NAME=AutoMarket - Soporte
# Compatibilidad: si solo existen estas (legado SendGrid), config/email.php las usa si MAIL_* está vacío
# SENDGRID_FROM_EMAIL=notificaciones@automarket.com.pa
# SENDGRID_FROM_NAME=AutoMarket Seminuevos
# SENDGRID_REPLY_TO=
# SENDGRID_REPLY_TO_NAME=AutoMarket

# URL de la aplicación
APP_URL=http://localhost:8086

# Chatbot (OpenAI). Crear clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
# CHATBOT_MODEL=gpt-4o-mini

# Voz (Realtime): URL base directa del servidor si usas Cloudflare
# REALTIME_INTERNAL_BASE_URL=http://127.0.0.1

# Configuración MySQL para Docker
MYSQL_ROOT_PASSWORD=motus_root_2024
MYSQL_DATABASE=motus_baes
MYSQL_USER=motus_user
MYSQL_PASSWORD=motus_pass_2024
